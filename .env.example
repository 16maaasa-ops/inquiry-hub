# Supabase（データベース・キュー）
# 注意: project1・project4 と同じ Supabase プロジェクトに相乗りしている（project5 専用スキーマで分離）。
# そのため URL・キーは project1/project4 の .env.local と同じ値になるのが正常。
NEXT_PUBLIC_SUPABASE_URL=
# サーバー専用。ブラウザに公開されないよう NEXT_PUBLIC_ を付けないこと
SUPABASE_SERVICE_ROLE_KEY=

# Claude API（AI分類）
ANTHROPIC_API_KEY=

# Slack（通知・ボタン操作）
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
# カテゴリ別チャネルID（Slackで各チャネルを右クリック→チャネル詳細を表示→一番下のIDをコピー）
SLACK_CHANNEL_RENTAL=
SLACK_CHANNEL_SALE=
SLACK_CHANNEL_VIEWING=
SLACK_CHANNEL_COMPLAINT=
SLACK_CHANNEL_OTHER=
SLACK_CHANNEL_SYSTEM_ALERTS=

# LINE（問い合わせ受信 + 部長への通知）
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
# クレーム通知を送る営業部長個人のLINEユーザーID（Uから始まる文字列）
LINE_MANAGER_USER_ID=

# Gmail（問い合わせメール取得。OAuth 2.0 リフレッシュトークン方式）
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# 問い合わせ受信用メールアドレス
GMAIL_ADDRESS=

# Cron エンドポイント保護用（Vercel が Cron 実行時に自動でこの値をヘッダーに付与する）
CRON_SECRET=

# アプリの公開URL（Slackカードへのリンク生成等に使用）
APP_BASE_URL=
